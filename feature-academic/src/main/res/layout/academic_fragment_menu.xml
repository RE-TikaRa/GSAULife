<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:ignore="UseCompoundDrawables">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:minHeight="?attr/actionBarSize"
        app:title="@string/academic_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            app:columnCount="2">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/academic_card_grades"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:clickable="true"
                android:contentDescription="@string/academic_feature_grades"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:minHeight="150dp"
                app:cardCornerRadius="16dp"
                app:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="noHideDescendants"
                    android:minHeight="150dp"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/academic_bg_icon_circle"
                        android:importantForAccessibility="no"
                        android:padding="15dp"
                        android:src="@drawable/academic_ic_grades"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/academic_feature_grades"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/academic_card_schedule"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:clickable="true"
                android:contentDescription="@string/academic_feature_schedule"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:minHeight="150dp"
                app:cardCornerRadius="16dp"
                app:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="noHideDescendants"
                    android:minHeight="150dp"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/academic_bg_icon_circle"
                        android:importantForAccessibility="no"
                        android:padding="15dp"
                        android:src="@drawable/academic_ic_schedule"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/academic_feature_schedule"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/academic_card_exams"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:clickable="true"
                android:contentDescription="@string/academic_feature_exams"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:minHeight="150dp"
                app:cardCornerRadius="16dp"
                app:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="noHideDescendants"
                    android:minHeight="150dp"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/academic_bg_icon_circle"
                        android:importantForAccessibility="no"
                        android:padding="15dp"
                        android:src="@drawable/academic_ic_exams"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/academic_feature_exams"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/academic_card_rankings"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_gravity="fill_horizontal"
                android:layout_margin="6dp"
                android:clickable="true"
                android:contentDescription="@string/academic_feature_rankings"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:minHeight="150dp"
                app:cardCornerRadius="16dp"
                app:layout_columnWeight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="noHideDescendants"
                    android:minHeight="150dp"
                    android:orientation="vertical"
                    android:paddingVertical="16dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/academic_bg_icon_circle"
                        android:importantForAccessibility="no"
                        android:padding="15dp"
                        android:src="@drawable/academic_ic_rankings"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/academic_feature_rankings"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.gridlayout.widget.GridLayout>
    </ScrollView>
</LinearLayout>
