<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/academic_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:minHeight="?attr/actionBarSize"
        app:navigationContentDescription="@string/academic_cd_back"
        app:navigationIcon="@drawable/academic_ic_back" />

    <include
        android:id="@+id/academic_cache_banner"
        layout="@layout/academic_view_cache_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/academic_schedule_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">
            <com.tika.gsaulife.academic.ui.AcademicScheduleGridView
                android:id="@+id/academic_schedule_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </ScrollView>

        <com.tika.gsaulife.academic.ui.AcademicStateView
            android:id="@+id/academic_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/academic_week_list"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/colorSurface"
        android:clipToPadding="false"
        android:paddingHorizontal="6dp"
        android:visibility="gone" />
</LinearLayout>
