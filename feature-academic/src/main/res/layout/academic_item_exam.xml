<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/academic_exam_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/academic_exam_ended"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/academic_bg_badge_muted"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="@string/academic_exam_ended"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/academic_exam_index"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/academic_bg_badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="12sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/academic_exam_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/academic_ic_time"
            app:drawableTint="?attr/colorOnSurfaceVariant" />
        <TextView
            android:id="@+id/academic_exam_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/academic_ic_location"
            app:drawableTint="?attr/colorOnSurfaceVariant" />
        <TextView
            android:id="@+id/academic_exam_seat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/academic_ic_seat"
            app:drawableTint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
