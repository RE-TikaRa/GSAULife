<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:supportsRtl="true"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false" />

        <service
            android:name=".widget.ScheduleWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <receiver
            android:name=".widget.TodayScheduleWidgetProvider"
            android:label="@string/academic_widget_today_title"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/academic_widget_today_info" />
        </receiver>

        <receiver
            android:name=".widget.UpcomingScheduleWidgetProvider"
            android:label="@string/academic_widget_upcoming_title"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/academic_widget_upcoming_info" />
        </receiver>

        <receiver
            android:name=".widget.ExamScheduleWidgetProvider"
            android:label="@string/academic_feature_exams"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/academic_widget_exams_info" />
        </receiver>
    </application>

</manifest>
