<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="@color/card_secondary">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_secondary" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_surface" />
            <corners android:radius="8dp" />
            <stroke android:width="1dp" android:color="@color/card_outline" />
        </shape>
    </item>
</ripple>
