<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="16dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/card_pay_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/card_bg_icon_button"
                android:contentDescription="@string/card_cd_back"
                android:padding="12dp"
                android:src="@drawable/card_ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/card_page_title"
                android:textColor="?attr/colorOnSurface"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg_surface"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/card_pay_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/card_pay_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp" />

            <FrameLayout
                android:id="@+id/card_pay_qr_container"
                android:layout_width="@dimen/card_pay_qr_size"
                android:layout_height="@dimen/card_pay_qr_size"
                android:layout_marginTop="28dp"
                android:background="@drawable/card_bg_qr"
                android:padding="22dp">

                <ImageView
                    android:id="@+id/card_pay_qr"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/card_cd_qr_refresh"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/card_pay_qr_progress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:indeterminateTint="?attr/colorPrimary"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/card_pay_qr_error"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:padding="8dp"
                    android:src="@drawable/card_ic_error"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/card_pay_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:accessibilityLiveRegion="polite"
                android:gravity="center"
                android:text="@string/card_pay_auto_refresh"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <Button
                android:id="@+id/card_pay_refresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/card_bg_button"
                android:minHeight="48dp"
                android:paddingHorizontal="28dp"
                android:paddingVertical="12dp"
                android:stateListAnimator="@null"
                android:text="@string/card_refresh"
                android:textColor="?attr/colorOnPrimary" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
