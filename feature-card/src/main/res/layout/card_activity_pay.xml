<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/card_pay_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/card_bg_icon_button"
            android:contentDescription="@string/card_cd_back"
            android:padding="10dp"
            android:src="@drawable/card_ic_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/card_page_title"
            android:textColor="@color/card_text"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/card_bg_surface"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/card_pay_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/card_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/card_pay_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/card_text_hint"
            android:textSize="15sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/card_bg_qr"
            android:padding="22dp">

            <ImageView
                android:id="@+id/card_pay_qr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/card_cd_qr"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/card_pay_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/card_pay_auto_refresh"
            android:textColor="@color/card_text_hint"
            android:textSize="14sp" />

        <Button
            android:id="@+id/card_pay_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_bg_button"
            android:minHeight="44dp"
            android:paddingHorizontal="28dp"
            android:stateListAnimator="@null"
            android:text="@string/card_refresh"
            android:textColor="@color/card_on_primary" />
    </LinearLayout>
</LinearLayout>
