<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/card_bg_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <View
        android:id="@+id/card_item_current"
        android:layout_width="4dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/card_bg_indicator" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/card_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/card_text"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="校园卡" />

        <TextView
            android:id="@+id/card_item_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/card_text_hint"
            android:textSize="13sp"
            tools:text="1073325020407  余额 20.00元" />
    </LinearLayout>
</LinearLayout>
