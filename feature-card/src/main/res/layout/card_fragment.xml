<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/card_page_title"
            android:textColor="@color/card_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/card_btn_refresh"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/card_bg_icon_button"
            android:contentDescription="@string/card_cd_refresh"
            android:padding="10dp"
            android:src="@drawable/card_ic_refresh" />

        <ImageButton
            android:id="@+id/card_btn_add"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/card_bg_icon_button"
            android:contentDescription="@string/card_cd_add"
            android:padding="10dp"
            android:src="@drawable/card_ic_add" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/card_bg_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_name_bar"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/card_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/card_no_card"
                android:textColor="@color/card_on_name_bar"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/card_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/card_on_name_bar"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_bg_qr"
            android:padding="18dp">

            <ImageView
                android:id="@+id/card_qr"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/card_cd_qr"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:id="@+id/card_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/card_add_hint"
            android:textColor="@color/card_text_hint"
            android:textSize="13sp" />

        <Button
            android:id="@+id/card_add_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/card_bg_button"
            android:minHeight="44dp"
            android:stateListAnimator="@null"
            android:text="@string/card_add"
            android:textColor="@color/card_on_primary" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="8dp"
        android:text="@string/card_list_title"
        android:textColor="@color/card_text_hint"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/card_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />
</LinearLayout>
