<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/card_bg_widget"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_bg_name_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/card_widget_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="校园卡" />

        <ImageView
            android:id="@+id/card_widget_refresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/card_bg_refresh_circle"
            android:contentDescription="@string/card_cd_refresh"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:src="@drawable/card_ic_refresh_light" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/card_bg_qr"
        android:padding="10dp">

        <ImageView
            android:id="@+id/card_widget_qr"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/card_cd_qr"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/card_widget_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="#66706A"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="@string/card_widget_refresh_hint" />
    </FrameLayout>
</LinearLayout>
